# LLM 服务提供商
# 可选值: mock | openai | ollama | volcano
# mock: 使用预设规则模拟回复（默认，无需 API Key）
LLM_PROVIDER=mock

# API Key（接入真实模型时填写）
LLM_API_KEY=

# 模型名称，例如：deepseek-v3 / gpt-4o / qwen-max
LLM_MODEL=

# API 基础地址（openai 兼容格式）
# OpenAI: https://api.openai.com/v1
# 火山引擎: https://ark.cn-beijing.volces.com/api/v3
# Ollama: http://localhost:11434/v1
LLM_BASE_URL=

# 服务端口（可选，默认 3001）
# PORT=3001
